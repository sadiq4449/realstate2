# Copy to .env and adjust. Used by docker-compose (local) and documented for production.

APP_NAME=RealStat Rental API
DEBUG=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=realstat

JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# local | s3
STORAGE_MODE=local
LOCAL_UPLOAD_DIR=./uploads
PUBLIC_MEDIA_BASE_URL=http://localhost:8000/media

# Production (S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# Cloudinary (optional alternative)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Stripe (omit for mock-only billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
