# WebSocket must reach the API port (Vite cannot proxy WS in this setup).
# Use the same hostname you open the app with (localhost vs 127.0.0.1).
VITE_WS_URL=ws://127.0.0.1:8000

# API URL is optional in dev: the app uses same-origin /api/v1 → Vite proxy → backend.
# Only set this if you disable the proxy:
# VITE_USE_API_PROXY=0
# VITE_API_URL=http://127.0.0.1:8000/api/v1
